{
  "name": "littleduck-mvp",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.10.0",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "build": "pnpm contract:types && pnpm -r build",
    "typecheck": "pnpm contract:types && pnpm -r typecheck && pnpm api:typecheck",
    "test": "pnpm api:test",
    "api:lint": "uv run --directory apps/api ruff check .",
    "api:typecheck": "uv run --directory apps/api mypy src",
    "api:test": "uv run --directory apps/api pytest",
    "api:migrate": "uv run --directory apps/api alembic upgrade head",
    "api:bootstrap-admin": "uv run --directory apps/api python -m littleduck_api.bootstrap_admin",
    "dev:api": "uv run --directory apps/api uvicorn littleduck_api.main:app --reload --host 127.0.0.1 --port 3000",
    "dev:user": "pnpm --filter @littleduck/user-web dev",
    "dev:admin": "pnpm --filter @littleduck/admin-web dev",
    "start:api": "uv run --directory apps/api uvicorn littleduck_api.main:app --host 127.0.0.1 --port 3000",
    "contract:lint": "redocly lint ../contracts/openapi.yaml --config redocly.yaml",
    "contract:types": "openapi-typescript ../contracts/openapi.yaml -o packages/contracts/src/generated.ts",
    "examples:check": "node scripts/check-sse-examples.mjs",
    "security:scan": "node scripts/scan-secrets.mjs",
    "mock": "node scripts/mock-server.mjs"
  },
  "devDependencies": {
    "@redocly/cli": "2.39.0",
    "openapi-typescript": "7.13.0",
    "typescript": "5.9.3"
  }
}
